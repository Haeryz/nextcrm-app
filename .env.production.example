# ============================================================
# NextCRM — Production Environment Variables (no domain)
# ============================================================
# Copy this file:  cp .env.production.example .env.production
# Run setup:       ./setup.sh
# Start:           docker compose --env-file .env.production up -d --build
# NEVER commit .env.production to version control.
# ============================================================

# ── Server address ───────────────────────────────────────────
# Replace with your server's IP or hostname, e.g. http://192.168.1.10:3000
NEXTAUTH_URL=http://localhost:3000
# Same value used for MinIO public presigned URLs
NEXT_PUBLIC_MINIO_ENDPOINT=http://localhost:9000

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=nextcrm
POSTGRES_PASSWORD=           # auto-generated by setup.sh
POSTGRES_DB=nextcrm

# ── MinIO (object storage) ───────────────────────────────────
MINIO_ROOT_USER=nextcrm
MINIO_ROOT_PASSWORD=         # auto-generated by setup.sh
MINIO_BUCKET=nextcrm

# ── NextAuth ─────────────────────────────────────────────────
# Auto-generated by setup.sh (openssl rand -base64 32)
NEXTAUTH_SECRET=
JWT_SECRET=

# ── Encryption (REQUIRED) ────────────────────────────────────
# Auto-generated by setup.sh (openssl rand -hex 32)
EMAIL_ENCRYPTION_KEY=

# ── Auth mode ────────────────────────────────────────────────
# true  = no login screen, everyone runs as guest admin (good for local/internal)
# false = require OAuth login (need GOOGLE_ID/GITHUB_ID below)
NEXTCRM_DISABLE_AUTH=true
NEXTCRM_GUEST_USER_ID=00000000-0000-0000-0000-000000000001
NEXTCRM_GUEST_USER_EMAIL=guest@nextcrm.local
NEXTCRM_GUEST_USER_NAME=NextCRM Guest
NEXTCRM_GUEST_USER_LANGUAGE=en

# ── OAuth providers (only needed if NEXTCRM_DISABLE_AUTH=false) ──
GOOGLE_ID=
GOOGLE_SECRET=
GITHUB_ID=
GITHUB_SECRET=

# ── pgAdmin ───────────────────────────────────────────────────
PGADMIN_EMAIL=admin@nextcrm.local
PGADMIN_PASSWORD=            # auto-generated by setup.sh

# ── AI / Enrichment (optional) ───────────────────────────────
OPENAI_API_KEY=

# ── Inngest background jobs (optional) ───────────────────────
# Sign up free at https://app.inngest.com — enables embeddings & enrichment
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ── Email sending via Resend (optional) ──────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# ── IMAP / SMTP email client (optional) ──────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ── Misc ─────────────────────────────────────────────────────
CRON_SECRET=                 # auto-generated by setup.sh
NEXT_PUBLIC_APP_NAME=NextCRM
NEXT_PUBLIC_APP_V=0.0.3-beta
